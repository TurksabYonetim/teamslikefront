{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    // lib ES2022 (target ES2020 olsa da): Vite/esbuild transpile'ı kendi yapar; lib
    // yalnızca evergreen tarayıcıda mevcut runtime API'lerini ifade eder (örn. Object.hasOwn).
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    }
  },
  "include": ["src", "vite.config.ts"]
}
